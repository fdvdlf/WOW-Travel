# ===== WhatsApp Cloud API =====
# Token del Business Manager para enviar mensajes salientes.
WHATSAPP_TOKEN=
# Versión del Graph API a usar (se prefiere mantenerlo alineado con Meta).
WHATSAPP_GRAPH_VERSION=v20.0

# Token secreto que debes registrar en Meta para la verificación del webhook.
VERIFY_TOKEN=

# Duración (en días) que se recuerda a un contacto para evitar automatizaciones
# repetidas. Si lo dejas vacío o en 0, el historial expira inmediatamente.
CONTACT_HISTORY_TTL_DAYS=30

# ===== OpenAI =====
# Clave del proyecto de OpenAI (necesaria para llamar al modelo gpt-5.1).
OPENAI_API_KEY=
# Opcional: cambia el modelo predeterminado o ajusta el endpoint y la temperatura.
OPENAI_MODEL=gpt-5.1
OPENAI_BASE_URL=https://api.openai.com
OPENAI_TEMPERATURE=0.4

# ===== Next.js =====
# Asegúrate de publicar el backend con HTTPS para que Meta pueda alcanzarlo.
NEXT_PUBLIC_SITE_URL=
